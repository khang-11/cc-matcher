rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Any authenticated user can read/write their own profile
    match /userProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Cards: readable/writable only by users listed in owners[]
    match /cards/{cardId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid in resource.data.account.owners;
      // Allow create if the creating user includes themselves as an owner
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.account.owners;
    }
  }
}
